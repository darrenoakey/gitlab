#!/usr/bin/env bash

# Colors
RED='\033[0;31m'
NC='\033[0m' # No Color

# Check if we're in a git repo
if ! git rev-parse --show-toplevel 1>/dev/null 2>/dev/null; then
  echo -e "${RED}Error: Not in a git repository.${NC}" >&2
  exit 1
fi

GIT_ROOT=$(git rev-parse --show-toplevel)
CUR_DIR=$(pwd)
REL_PATH="${CUR_DIR#${GIT_ROOT}}"
REL_PATH=${REL_PATH#/} # Remove leading slash if present

# Get git remote url (use 'origin' by default)
REMOTE_URL=$(git remote get-url origin 2>/dev/null)
if [[ -z "$REMOTE_URL" ]]; then
  echo -e "${RED}Error: No remote named 'origin' found.${NC}" >&2
  exit 1
fi

# Only allow GitLab (any hostname/gitlab[.]com)
if [[ ! "$REMOTE_URL" =~ (git@gitlab\.com:|https://gitlab\.com/) ]]; then
  echo -e "${RED}Error: Remote is not a GitLab URL ('gitlab.com').${NC}" >&2
  exit 1
fi

# Extract owner/repo from remote url
if [[ "$REMOTE_URL" =~ git@gitlab.com:([^/]+)/([^\.]+)(\.git)?$ ]]; then
  OWNER="${BASH_REMATCH[1]}"
  REPO="${BASH_REMATCH[2]}"
elif [[ "$REMOTE_URL" =~ https://gitlab.com/([^/]+)/([^\.]+)(\.git)? ]]; then
  OWNER="${BASH_REMATCH[1]}"
  REPO="${BASH_REMATCH[2]}"
else
  echo -e "${RED}Error: Could not parse GitLab remote URL.${NC}" >&2
  exit 1
fi

# Determine current branch
BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Compose the URL
if [[ -n "$REL_PATH" ]]; then
  URL="https://gitlab.com/${OWNER}/${REPO}/-/tree/${BRANCH}/${REL_PATH}"
else
  URL="https://gitlab.com/${OWNER}/${REPO}/-/tree/${BRANCH}"
fi

echo "Opening: $URL"
# Try to use xdg-open, open (mac), or fallback
if command -v xdg-open >/dev/null; then
  xdg-open "$URL"
elif command -v open >/dev/null; then
  open "$URL"
else
  echo "$URL"
fi
